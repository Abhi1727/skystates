# Server
NODE_ENV=production
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://skyreviews.us

# JWT - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-strong-random-secret-min-32-chars
JWT_EXPIRE=7d

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Clerk (get from https://dashboard.clerk.com/last-active?path=api-keys)
# When set, auth uses Clerk instead of JWT
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Email - for order confirmation / welcome messages (optional)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM="Sky States" <noreply@skyreviews.us>

# Database - NOT USED YET (project uses in-memory store)
# When you add PostgreSQL, set:
# DATABASE_URL=postgresql://user:password@localhost:5432/skystates
